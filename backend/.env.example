# RouteScope Backend Configuration
# Copy this file to .env and fill in your values.
# Never commit .env — it contains real credentials.

# ── GNS3 ─────────────────────────────────────────────────────────────────────
GNS3_URL=http://localhost:3080
GNS3_USER=admin
GNS3_PASS=admin
# Leave blank to auto-discover the open project
GNS3_PROJECT_ID=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./routescope.db

# ── Simulation ────────────────────────────────────────────────────────────────
# true  → synthetic metrics only (no GNS3 required)
# false → live GNS3 topology + real collector blend
SIMULATION_MODE=false

# ── Metric collection ─────────────────────────────────────────────────────────
METRIC_UPDATE_INTERVAL=2.0
ALGORITHM_TIMEOUT=30.0

# ── Layer 1 collectors (all optional) ────────────────────────────────────────
# iperf3: set to IP of a host running `iperf3 -s`
IPERF3_SERVER=
# Netmiko default device type for SSH/telnet
NETMIKO_DEVICE_TYPE=cisco_ios

# ── Layer 2 graph storage ─────────────────────────────────────────────────────
# Tier 1 (NetworkX in-memory):  node_count <= 50000
# Tier 2 (Neo4j Community):     50000 < node_count <= 500000
# Tier 3 (Neo4j cluster/Kafka): node_count > 500000  [future]

# Neo4j connection (required for Tier 2)
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASS=routescope

# Set to 2 to force Tier 2 (Neo4j) regardless of node count — useful for demos
# 0 = auto-select based on node count
FORCE_STORAGE_TIER=0
